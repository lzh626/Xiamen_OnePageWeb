# 第三方API配置 (山河天气)
WEATHER_API_URL=http://shanhe.kim/api/za/tianqi.php
WEATHER_TIMEOUT_SECONDS=3
WEATHER_RETRY_COUNT=2
WEATHER_CACHE_TTL_SECONDS=1800

# 数据库配置
DB_PATH=./xiamen_travel.db

# 大模型推荐配置（可选：不配置则使用规则引擎推荐）
# RECOMMENDER_TYPE=rule       # 规则引擎（默认）
# RECOMMENDER_TYPE=mock       # Mock LLM模拟
# RECOMMENDER_TYPE=llm        # 真实大模型（需同时配置下方密钥）
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-3.5-turbo
# LLM_TIMEOUT_SECONDS=10
